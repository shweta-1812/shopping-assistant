FROM python:3.10-slim

WORKDIR /app

COPY requirements_frontend.txt requirements.txt
RUN pip install --upgrade pip && pip install --no-cache-dir -r requirements.txt

# Copy frontend code
COPY shopping-assistant-front frontend
COPY shopping-assistant-back/shoppingassistant shoppingassistant

ENV PYTHONPATH=/app
ENV STREAMLIT_SERVER_PORT=8080
ENV STREAMLIT_SERVER_HEADLESS=true
ENV STREAMLIT_SERVER_ENABLECORS=false

EXPOSE 8080

CMD ["streamlit", "run", "frontend/app.py", "--server.address=0.0.0.0"]
